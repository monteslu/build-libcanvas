+// ── GPU (Ganesh GL) ─────────────────────────────────────────────────────────
+#if defined(SK_GANESH)
+// Host loader signature. The frontend's get_proc_address (RetroArch's
+// retro_hw_get_proc_address_t) is `void*(*)(const char* sym)` — a SINGLE arg.
+// Skia's GrGLGetProc is two-arg `(void* ctx, const char* name)`; the trampoline
+// below bridges them (passes the host loader as Skia's ctx, drops the ctx when
+// calling). Mismatching the arity (calling a 1-arg fn as 2-arg) is UB and
+// hangs/crashes, so this typedef MUST match the frontend exactly.
+using HostGetProc = void* (*)(const char*);
+
+skiac_grcontext* skiac_grcontext_make_gl(void* get_proc, void* ctx) {
+  // GrGLMakeAssembledInterface(ctx, getProc) calls getProc(ctx, name) for each
+  // GL entry point. We pass the host loader pointer as Skia's `ctx` and use a
+  // stateless trampoline that forwards to it. (void* ctx) userdata is unused —
+  // the loader is ctx-less; if a host needs userdata, fold it into get_proc.
+  (void)ctx;
+  // Prefer the platform NATIVE interface: it loads GL entry points directly from
+  // the current context's driver, so the full draw pipeline (not just clear) is
+  // wired. The assembled-from-proc-address interface (RA's get_proc_address) was
+  // missing entry points the draw pipeline needs -> draws silently no-op'd while
+  // clear() worked. Fall back to assembled only if native is unavailable.
+  sk_sp<const GrGLInterface> iface = GrGLMakeNativeInterface();
+  if (!iface && get_proc) {
+    iface = GrGLMakeAssembledInterface(
+        get_proc, [](void* c, const char* name) -> GrGLFuncPtr {
+          return reinterpret_cast<GrGLFuncPtr>(
+              reinterpret_cast<HostGetProc>(c)(name));
+        });
+  }
+  if (!iface) return nullptr;
+  GrContextOptions opts;
+  sk_sp<GrDirectContext> dctx = GrDirectContexts::MakeGL(iface, opts);
+  if (!dctx) return nullptr;
+  return reinterpret_cast<skiac_grcontext*>(dctx.release());
+}
+
+void skiac_grcontext_destroy(skiac_grcontext* gr) {
+  if (!gr) return;
+  GRCONTEXT_CAST->unref();
+}
+
+void skiac_grcontext_reset(skiac_grcontext* gr) {
+  if (!gr) return;
+  // Skia's GL state cache is stale after the frontend issued its own GL calls.
+  GRCONTEXT_CAST->resetContext();
+}
+
+void skiac_grcontext_flush(skiac_grcontext* gr, skiac_surface* c_surface) {
+  if (!gr) return;
+  if (c_surface) {
+    GRCONTEXT_CAST->flush(SURFACE_CAST);
+  }
+  GRCONTEXT_CAST->submit();
+}
+
+skiac_surface* skiac_surface_create_gpu(skiac_grcontext* gr,
+                                        int width,
+                                        int height,
+                                        uint8_t cs) {
+  if (!gr) return nullptr;
+  SkGraphics::Init();
+  auto color_space = COLOR_SPACE_CAST;
+  auto info = SkImageInfo::Make(width, height, kRGBA_8888_SkColorType,
+                                kPremul_SkAlphaType, color_space);
+  // Top-left origin to match the CPU raster surface's pixel layout, so the
+  // host's existing flip logic and HUD coordinates are unchanged.
+  sk_sp<SkSurface> surface = SkSurfaces::RenderTarget(
+      GRCONTEXT_CAST, skgpu::Budgeted::kYes, info, 0,
+      kTopLeft_GrSurfaceOrigin, nullptr);
+  if (!surface) return nullptr;
+  return reinterpret_cast<skiac_surface*>(surface.release());
+}
+
+unsigned skiac_surface_gpu_texture_id(skiac_surface* c_surface) {
+  if (!c_surface) return 0;
+  GrBackendTexture tex = SkSurfaces::GetBackendTexture(
+      SURFACE_CAST, SkSurfaces::BackendHandleAccess::kFlushRead);
+  if (!tex.isValid()) return 0;
+  GrGLTextureInfo glInfo;
+  if (!GrBackendTextures::GetGLTextureInfo(tex, &glInfo)) return 0;
+  return glInfo.fID;
+}
+
+// Clear the GPU surface to fully transparent. Used for the HUD overlay surface:
+// the game's fillText/fillRect draws into it (transparent elsewhere), and the
+// host alpha-blends it over the separately-presented 3D scene at present time.
+void skiac_surface_gpu_clear_transparent(skiac_grcontext* gr,
+                                         skiac_surface* c_surface) {
+  if (!c_surface) return;
+  // DEBUG: JSGAME_GPU_HUDTINT -> clear to semi-transparent blue to verify the
+  // HUD surface reaches the screen via the blend (isolates surface/blend from
+  // fillText). Normal: fully transparent.
+  SURFACE_CAST->getCanvas()->clear(SK_ColorTRANSPARENT);
+}
+
+#else  // !SK_GANESH — CPU-only Skia: stub the GPU API so the host falls back.
+skiac_grcontext* skiac_grcontext_make_gl(void*, void*) { return nullptr; }
+void skiac_grcontext_destroy(skiac_grcontext*) {}
+void skiac_grcontext_reset(skiac_grcontext*) {}
+void skiac_grcontext_flush(skiac_grcontext*, skiac_surface*) {}
+skiac_surface* skiac_surface_create_gpu(skiac_grcontext*, int, int, uint8_t) {
+  return nullptr;
+}
+unsigned skiac_surface_gpu_texture_id(skiac_surface*) { return 0; }
+void skiac_surface_gpu_clear_transparent(skiac_grcontext*, skiac_surface*) {}
+#endif  // SK_GANESH
