+// Process GPU (Ganesh GL) direct context. Single-threaded use (the host's
+// libretro thread is the only one that touches GL), so a thread-local is safe
+// and avoids Send/Sync bounds on the non-thread-safe GrDirectContext. Lazily
+// created from the frontend's GL proc-address; null on CPU-only Skia.
+thread_local! {
+  static GR_CONTEXT: RefCell<Option<GrContext>> = const { RefCell::new(None) };
+}
+
+/// Init (idempotent) the process GrContext from a GL proc-address loader. The
+/// current thread's GL context must be current. Returns true on success.
+pub(crate) fn gpu_init(get_proc: *mut std::ffi::c_void) -> bool {
+  GR_CONTEXT.with(|c| {
+    let mut slot = c.borrow_mut();
+    if slot.is_some() {
+      return true;
+    }
+    if let Some(gr) = GrContext::make_gl(get_proc) {
+      *slot = Some(gr);
+      true
+    } else {
+      false
+    }
+  })
+}
+
+/// Whether the process GrContext is live (GPU mode available).
+pub(crate) fn gpu_ready() -> bool {
+  GR_CONTEXT.with(|c| c.borrow().is_some())
+}
+
+/// Run a closure with the process GrContext, if any.
+pub(crate) fn with_gr<R>(f: impl FnOnce(&GrContext) -> R) -> Option<R> {
+  GR_CONTEXT.with(|c| c.borrow().as_ref().map(f))
+}
